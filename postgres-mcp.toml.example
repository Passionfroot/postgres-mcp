# Path to your Prisma schema file (optional but recommended).
# Enables Prisma model name resolution, field mappings, and relationship detection.
# The MCP reads this file on startup — no build step needed.
# prisma_schema_path = "~/work/myproject/prisma/schema.prisma"

# Production: locked down, tunneled, read-only
[[sources]]
id = "production"
dsn = "postgres://$DB_USER:$DB_PASS@db-host:5432/mydb?sslmode=require"
readonly = true
# ssh_host = "bastion.example.com"
# ssh_user = "deploy"
# ssh_key = "~/.ssh/key.pem"

# Per-tenant: RLS-scoped via a restricted role + a session GUC the policies read.
# Because the tenant scope lives in role/session_vars, restrict_session_state
# defaults to true here: submitted queries that run SET / RESET / set_config /
# set_role are rejected, so a query cannot re-point app.tenant_id at another tenant
# or escape the role. Leave it on for any tenant-scoped source.
[[sources]]
id = "tenant"
dsn = "postgres://$DB_USER:$DB_PASS@db-host:5432/mydb?sslmode=require"
readonly = true
role = "tenant_reader"
session_vars = { "app.tenant_id" = "$TENANT_ID" }

# Local: relaxed defaults for development. No role/session_vars, so
# restrict_session_state defaults to false and free-form SET is allowed. Set it
# explicitly to false to keep that even if you add a role locally.
[[sources]]
id = "local"
dsn = "postgres://localhost/mydb"
timeout = 30
pool_max = 3
allow_multi_statements = true
restrict_session_state = false

# Audit log (optional) — logs all queries across all sources as JSONL
# [audit_log]
# log_file = "~/.local/share/postgres-mcp/audit.jsonl"
# max_size = 10485760  # 10MB, omit for unlimited
